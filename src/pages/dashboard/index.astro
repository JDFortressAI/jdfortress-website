<!-- Step 1: inject server data (IIFE scoped — only writes to window) -->
<script is:inline define:vars={{ userName: user.name, userEmail: user.email, stageLabels, stageOrder, stageColors, vertLabels, srcLabels }}>
  window.__CRM = {
    userName:  userName,
    userEmail: userEmail,
    SL:  JSON.parse(stageLabels),
    SO:  JSON.parse(stageOrder),
    SC:  JSON.parse(stageColors),
    VL:  JSON.parse(vertLabels),
    SRL: JSON.parse(srcLabels),
  };
</script>

<!-- Step 2: app logic (plain is:inline — no define:vars — Astro does NOT wrap in IIFE) -->
<script is:inline>
  var SL  = window.__CRM.SL;
  var SO  = window.__CRM.SO;
  var SC  = window.__CRM.SC;
  var VL  = window.__CRM.VL;
  var SRL = window.__CRM.SRL;
  var userName  = window.__CRM.userName;
  var userEmail = window.__CRM.userEmail;

  var leads = [];
  var dragId = null;   // id of card being dragged
  var modalLeadId = null; // lead currently open in modal

  // ── Demo toggle state ─────────────────────────────────────────
  var showDemo = localStorage.getItem('jdf-show-demo') !== 'false'; // default ON

  function setShowDemo(val) {
    showDemo = val;
    localStorage.setItem('jdf-show-demo', val ? 'true' : 'false');
    var btn = document.getElementById('btn-demo-toggle');
    if (btn) {
      btn.textContent = showDemo ? 'Demo: visible' : 'Demo: hidden';
      btn.classList.toggle('active', showDemo);
    }
    renderAll();
    if (typeof renderLeadsTab === 'function') renderLeadsTab();
  }

  function visibleLeads() {
    return showDemo ? leads : leads.filter(function(l) { return !l.isDemo; });
  }

  // ── Utils ─────────────────────────────────────────────────────
  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function escAttr(s) { return esc(s); }
  function fmt(n) { return n != null ? '£' + Number(n).toLocaleString('en-GB') : '—'; }
  function isOverdue(l) {
    return l.nextActionDue && new Date(l.nextActionDue) < new Date() && l.stage !== 'won' && l.stage !== 'lost';
  }
  function fmtDate(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
  }
  function isoToDateInput(iso) {
    if (!iso) return '';
    return new Date(iso).toISOString().slice(0, 10);
  }

  // ── API ───────────────────────────────────────────────────────
  async function fetchLeads() {
    var res = await fetch('/api/crm/leads');
    if (res.status === 401) { window.location.href = '/'; return; }
    leads = await res.json();
    renderAll();
  }

  async function apiPatch(id, patch) {
    var res = await fetch('/api/crm/leads?id=' + id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(patch),
    });
    if (!res.ok) throw new Error('Save failed');
    var updated = await res.json();
    var idx = leads.findIndex(function(l) { return l.id === id; });
    if (idx !== -1) leads[idx] = updated;
    return updated;
  }

  async function apiCreate(body) {
    var res = await fetch('/api/crm/leads', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!res.ok) { var e = await res.json(); throw new Error(e.error || 'Create failed'); }
    var lead = await res.json();
    leads.push(lead);
    return lead;
  }

  // ── Render all ────────────────────────────────────────────────
  function renderAll() {
    var vis = visibleLeads();
    renderStats(vis);
    renderKanban(vis);
    renderCustomers(vis);
    renderContacts(vis);
    renderAnalytics(vis);
  }

  // ── Stats ─────────────────────────────────────────────────────
  function renderStats(vis) {
    var active = vis.filter(function(l) { return l.stage !== 'won' && l.stage !== 'lost'; });
    var pipeline = active.reduce(function(s,l) { return s + (l.estimatedValue || 0); }, 0);
    var won = vis.filter(function(l) { return l.stage === 'won'; });
    var wonVal = won.reduce(function(s,l) { return s + (l.estimatedValue || 0); }, 0);
    var due = vis.filter(function(l) { return isOverdue(l); });
    document.getElementById('s-active').textContent = active.length;
    document.getElementById('s-pipeline').textContent = fmt(pipeline);
    document.getElementById('s-customers').textContent = won.length;
    document.getElementById('s-customers-v').textContent = fmt(wonVal) + ' total';
    document.getElementById('s-due').textContent = due.length;
  }

  // ── Kanban ────────────────────────────────────────────────────
  function renderKanban(vis) {
    var board = document.getElementById('kanban');
    board.innerHTML = SO.map(function(stage) {
      var col = vis.filter(function(l) { return l.stage === stage; });
      var color = SC[stage];
      var cards = col.map(function(l) {
        var od = isOverdue(l);
        return '<div class="kcard" draggable="true" data-id="' + escAttr(l.id) + '" style="border-left-color:' + color + '">' +
          '<div class="kcard-company">' + esc(l.companyName) + (l.isDemo ? '<span class="demo-badge">demo</span>' : '') + '</div>' +
          '<div class="kcard-contact">' + esc(l.contactName) + '</div>' +
          '<div class="kcard-row">' +
            '<span class="vtag">' + esc(VL[l.vertical] || l.vertical) + '</span>' +
            (l.estimatedValue ? '<span class="vval">' + fmt(l.estimatedValue) + '</span>' : '') +
          '</div>' +
          (l.nextAction ? '<div class="kcard-action' + (od ? ' overdue' : '') + '">' + (od ? '⚠ ' : '→ ') + esc(l.nextAction) + '</div>' : '') +
        '</div>';
      }).join('');
      return '<div class="kcol" data-stage="' + stage + '">' +
        '<div class="kcol-hd">' +
          '<span class="kcol-title" style="color:' + color + '">' + esc(SL[stage]) + '</span>' +
          '<span class="kcol-count">' + col.length + '</span>' +
        '</div>' +
        '<div class="kcards" data-stage="' + stage + '">' + (cards || '<div class="kempty">Drop here</div>') + '</div>' +
      '</div>';
    }).join('');

    // Wire card events
    board.querySelectorAll('.kcard').forEach(function(card) {
      // Click to open
      card.addEventListener('click', function(e) {
        if (!e.defaultPrevented) openLead(this.dataset.id);
      });
      // Drag start
      card.addEventListener('dragstart', function(e) {
        dragId = this.dataset.id;
        this.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', dragId);
      });
      card.addEventListener('dragend', function() {
        this.classList.remove('dragging');
        dragId = null;
        board.querySelectorAll('.kcol').forEach(function(c) { c.classList.remove('drag-over'); });
      });
    });

    // Wire column drop zones
    board.querySelectorAll('.kcol').forEach(function(col) {
      col.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        board.querySelectorAll('.kcol').forEach(function(c) { c.classList.remove('drag-over'); });
        col.classList.add('drag-over');
      });
      col.addEventListener('dragleave', function(e) {
        if (!col.contains(e.relatedTarget)) col.classList.remove('drag-over');
      });
      col.addEventListener('drop', function(e) {
        e.preventDefault();
        col.classList.remove('drag-over');
        var id = e.dataTransfer.getData('text/plain') || dragId;
        if (!id) return;
        var newStage = col.dataset.stage;
        var lead = leads.find(function(l) { return l.id === id; });
        if (!lead || lead.stage === newStage) return;
        apiPatch(id, { stage: newStage }).then(function() {
          renderAll();
        }).catch(function(err) { alert('Could not move card: ' + err.message); });
      });
    });
  }

  // ── Customers ─────────────────────────────────────────────────
  function renderCustomers(vis) {
    var grid = document.getElementById('cust-grid');
    var won = vis.filter(function(l) { return l.stage === 'won'; });
    if (!won.length) {
      grid.innerHTML = '<div class="cust-empty">No customers yet — won deals will appear here.</div>';
      return;
    }
    grid.innerHTML = won.map(function(l) {
      var noteCount = (l.notes || []).length;
      return '<div class="cust-card" data-id="' + escAttr(l.id) + '">' +
        '<div class="cust-name">' + esc(l.companyName) + (l.isDemo ? '<span class="demo-badge">demo</span>' : '') + '</div>' +
        '<div class="cust-contact">' + esc(l.contactName) + ' · ' + esc(l.contactEmail) + '</div>' +
        '<div class="cust-row">' +
          '<span class="cust-value">' + (l.estimatedValue ? fmt(l.estimatedValue) : '—') + '</span>' +
          '<span class="cust-date">' + fmtDate(l.updatedAt) + '</span>' +
        '</div>' +
        (noteCount ? '<div class="cust-notes">' + noteCount + ' note' + (noteCount > 1 ? 's' : '') + '</div>' : '') +
      '</div>';
    }).join('');
    grid.querySelectorAll('.cust-card').forEach(function(card) {
      card.addEventListener('click', function() { openLead(this.dataset.id); });
    });
  }

  // ── Contacts ──────────────────────────────────────────────────
  function renderContacts(data) {
    var tbody = document.getElementById('contacts-body');
    if (!data.length) { tbody.innerHTML = '<tr><td colspan="8" class="no-data">No contacts found.</td></tr>'; return; }
    tbody.innerHTML = data.map(function(l) {
      var color = SC[l.stage];
      var od = isOverdue(l);
      var isJ = (l.assignedTo || '').startsWith('joseph');
      var initials = (l.assignedTo || '').split('@')[0].slice(0,2).toUpperCase();
      return '<tr data-id="' + escAttr(l.id) + '">' +
        '<td style="font-weight:600;color:#f1f5f9">' + esc(l.companyName) + (l.isDemo ? '<span class="demo-badge">demo</span>' : '') + '</td>' +
        '<td>' + esc(l.contactName) + '</td>' +
        '<td style="color:rgba(255,255,255,0.38);font-size:0.78rem">' + esc(l.contactEmail) + '</td>' +
        '<td><span class="pill" style="background:' + color + '1a;color:' + color + '">' + esc(SL[l.stage]) + '</span></td>' +
        '<td style="color:rgba(255,255,255,0.42);font-size:0.78rem">' + esc(VL[l.vertical] || l.vertical) + '</td>' +
        '<td>' + (l.estimatedValue ? fmt(l.estimatedValue) : '—') + '</td>' +
        '<td><span class="avatar" style="background:' + (isJ ? 'rgba(30,111,245,0.18)' : 'rgba(124,58,237,0.18)') + ';color:' + (isJ ? '#60a5fa' : '#c4b5fd') + '">' + initials + '</span></td>' +
        '<td style="font-size:0.78rem;color:' + (od ? '#f87171' : 'rgba(255,255,255,0.32)') + ';max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' +
          (od ? '⚠ ' : '') + esc(l.nextAction || '—') +
        '</td>' +
      '</tr>';
    }).join('');
    tbody.querySelectorAll('tr[data-id]').forEach(function(row) {
      row.addEventListener('click', function() { openLead(this.dataset.id); });
    });
  }

  // ── Analytics ─────────────────────────────────────────────────
  function renderAnalytics(vis) {
    renderBars('ch-stage', SO.map(function(s) {
      return { label: SL[s], n: vis.filter(function(l) { return l.stage === s; }).length, color: SC[s] };
    }));
    renderBars('ch-vertical', ['law_firm','in_house_legal','finance','healthcare','charity','enterprise','other'].map(function(v) {
      return { label: VL[v], n: vis.filter(function(l) { return l.vertical === v; }).length, color: '#1E6FF5' };
    }));
    renderBars('ch-source', ['website','referral','linkedin','cold_outreach','event','other'].map(function(s) {
      return { label: SRL[s], n: vis.filter(function(l) { return l.source === s; }).length, color: '#7c3aed' };
    }));
    renderBars('ch-value', SO.map(function(s) {
      var v = vis.filter(function(l) { return l.stage === s && l.estimatedValue; })
                   .reduce(function(a,l) { return a + (l.estimatedValue||0); }, 0);
      return { label: SL[s], n: v, color: SC[s], prefix: '£' };
    }));
  }

  function renderBars(id, items) {
    var el = document.getElementById(id);
    var max = Math.max.apply(null, items.map(function(i) { return i.n; }).concat([1]));
    var nonEmpty = items.filter(function(i) { return i.n > 0; });
    if (!nonEmpty.length) { el.innerHTML = '<div class="no-data">No data yet.</div>'; return; }
    el.innerHTML = nonEmpty.map(function(i) {
      var pct = (i.n / max * 100).toFixed(1);
      var display = (i.prefix || '') + (i.n > 999 ? Number(i.n).toLocaleString('en-GB') : i.n);
      return '<div class="bar-row">' +
        '<span class="bar-lbl">' + esc(i.label) + '</span>' +
        '<div class="bar-track"><div class="bar-fill" style="width:' + pct + '%;background:' + i.color + '"></div></div>' +
        '<span class="bar-n">' + display + '</span>' +
      '</div>';
    }).join('');
  }

  // ── Modal ─────────────────────────────────────────────────────
  function openLead(id) {
    var l = leads.find(function(x) { return x.id === id; });
    if (!l) return;
    modalLeadId = id;

    // Header
    var compInput = document.getElementById('modal-company-input');
    compInput.value = l.companyName;
    var stagePill = document.getElementById('modal-stage-pill');
    stagePill.textContent = SL[l.stage];
    stagePill.style.background = SC[l.stage] + '22';
    stagePill.style.color = SC[l.stage];

    var od = isOverdue(l);

    // Build body: editable fields + notes
    var stageOpts = SO.map(function(s) {
      return '<option value="' + s + '"' + (s === l.stage ? ' selected' : '') + '>' + SL[s] + '</option>';
    }).join('');
    var vertOpts = Object.keys(VL).map(function(v) {
      return '<option value="' + v + '"' + (v === l.vertical ? ' selected' : '') + '>' + VL[v] + '</option>';
    }).join('');
    var srcOpts = Object.keys(SRL).map(function(s) {
      return '<option value="' + s + '"' + (s === l.source ? ' selected' : '') + '>' + SRL[s] + '</option>';
    }).join('');
    var assignOpts = ['joseph@jdfortress.com','dev@jdfortress.com'].map(function(e) {
      return '<option value="' + e + '"' + (e === l.assignedTo ? ' selected' : '') + '>' + e + '</option>';
    }).join('');

    document.getElementById('modal-body').innerHTML =
      '<div class="modal-section">' +
        '<div class="modal-section-title">Details</div>' +
        '<div class="edit-grid">' +
          '<div class="fg"><label class="fl">Contact Name</label><input class="fi" id="e-contact" type="text" value="' + escAttr(l.contactName) + '" /></div>' +
          '<div class="fg"><label class="fl">Email</label><input class="fi" id="e-email" type="email" value="' + escAttr(l.contactEmail) + '" /></div>' +
          '<div class="fg"><label class="fl">Phone</label><input class="fi" id="e-phone" type="tel" value="' + escAttr(l.contactPhone || '') + '" /></div>' +
          '<div class="fg"><label class="fl">Est. Value (£)</label><input class="fi" id="e-value" type="number" value="' + escAttr(l.estimatedValue || '') + '" /></div>' +
          '<div class="fg"><label class="fl">Stage</label><select class="fsel" id="e-stage">' + stageOpts + '</select></div>' +
          '<div class="fg"><label class="fl">Vertical</label><select class="fsel" id="e-vertical">' + vertOpts + '</select></div>' +
          '<div class="fg"><label class="fl">Source</label><select class="fsel" id="e-source">' + srcOpts + '</select></div>' +
          '<div class="fg"><label class="fl">Assigned To</label><select class="fsel" id="e-assigned">' + assignOpts + '</select></div>' +
          '<div class="fg"><label class="fl">Next Action</label><input class="fi" id="e-action" type="text" value="' + escAttr(l.nextAction || '') + '" /></div>' +
          '<div class="fg"><label class="fl">Action Due</label><input class="fi" id="e-due" type="date" value="' + escAttr(isoToDateInput(l.nextActionDue)) + '" /></div>' +
        '</div>' +
      '</div>' +
      '<hr class="divider" />' +
      '<div class="modal-section">' +
        '<div class="modal-section-title">Notes</div>' +
        '<div class="notes-list" id="modal-notes">' +
          ((l.notes && l.notes.length)
            ? l.notes.map(function(n) {
                return '<div class="note-item">' +
                  '<div class="note-meta">' + esc(n.author) + ' · ' + fmtDate(n.createdAt) + '</div>' +
                  '<div class="note-text">' + esc(n.text) + '</div>' +
                '</div>';
              }).join('')
            : '<div class="no-data">No notes yet.</div>') +
        '</div>' +
        '<textarea class="note-input" id="note-input" placeholder="Add a note…"></textarea>' +
        '<div style="margin-top:8px"><button class="btn-primary" id="btn-add-note">Add Note</button></div>' +
      '</div>';

    // Wire add note
    document.getElementById('btn-add-note').addEventListener('click', function() {
      var text = (document.getElementById('note-input').value || '').trim();
      if (!text) return;
      var newNote = { id: 'note-' + Date.now(), text: text, author: userEmail, createdAt: new Date().toISOString() };
      var updatedNotes = (l.notes || []).concat([newNote]);
      apiPatch(l.id, { notes: updatedNotes }).then(function(updated) {
        l = updated;
        leads[leads.findIndex(function(x) { return x.id === id; })] = updated;
        openLead(id);
      }).catch(function(e) { alert('Could not add note: ' + e.message); });
    });

    document.getElementById('overlay').classList.add('open');
  }

  function collectModalEdits() {
    return {
      companyName:   document.getElementById('modal-company-input').value.trim(),
      contactName:   document.getElementById('e-contact').value.trim(),
      contactEmail:  document.getElementById('e-email').value.trim(),
      contactPhone:  document.getElementById('e-phone').value.trim() || undefined,
      estimatedValue: parseInt(document.getElementById('e-value').value) || undefined,
      stage:         document.getElementById('e-stage').value,
      vertical:      document.getElementById('e-vertical').value,
      source:        document.getElementById('e-source').value,
      assignedTo:    document.getElementById('e-assigned').value,
      nextAction:    document.getElementById('e-action').value.trim() || undefined,
      nextActionDue: (function() {
        var d = document.getElementById('e-due').value;
        return d ? new Date(d).toISOString() : undefined;
      })(),
    };
  }

  function closeModal() {
    document.getElementById('overlay').classList.remove('open');
    document.getElementById('saved-flash').classList.remove('show');
    modalLeadId = null;
  }

  // ── Tabs ──────────────────────────────────────────────────────
  function switchTab(name) {
    document.querySelectorAll('.section').forEach(function(s) { s.classList.remove('active'); });
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
    document.getElementById('tab-' + name).classList.add('active');
    document.querySelector('.tab[data-tab="' + name + '"]').classList.add('active');
  }

  // ── Boot ──────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('user-name').textContent = userName;

    // Demo toggle
    var demoBtn = document.getElementById('btn-demo-toggle');
    demoBtn.textContent = showDemo ? 'Demo: visible' : 'Demo: hidden';
    if (showDemo) demoBtn.classList.add('active');
    demoBtn.addEventListener('click', function() { setShowDemo(!showDemo); });

    // Tabs
    document.querySelectorAll('.tab').forEach(function(t) {
      t.addEventListener('click', function() { switchTab(this.dataset.tab); });
    });

    // Logout
    document.getElementById('btn-logout').addEventListener('click', function() {
      fetch('/api/auth/logout', { method: 'POST' }).then(function() { window.location.href = '/'; });
    });

    // Modal close
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('btn-modal-cancel').addEventListener('click', closeModal);
    document.getElementById('overlay').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });

    // Modal save
    document.getElementById('btn-modal-save').addEventListener('click', function() {
      if (!modalLeadId) return;
      var patch = collectModalEdits();
      var btn = this;
      btn.textContent = 'Saving…';
      btn.disabled = true;
      apiPatch(modalLeadId, patch).then(function() {
        renderAll();
        btn.textContent = 'Save Changes';
        btn.disabled = false;
        var flash = document.getElementById('saved-flash');
        flash.classList.add('show');
        setTimeout(function() { flash.classList.remove('show'); }, 2000);
        // Update stage pill live
        var stage = patch.stage;
        var stagePill = document.getElementById('modal-stage-pill');
        stagePill.textContent = SL[stage];
        stagePill.style.background = SC[stage] + '22';
        stagePill.style.color = SC[stage];
      }).catch(function(e) {
        alert('Save failed: ' + e.message);
        btn.textContent = 'Save Changes';
        btn.disabled = false;
      });
    });

    // Add lead panel
    document.getElementById('btn-add-toggle').addEventListener('click', function() {
      document.getElementById('add-panel').classList.toggle('open');
    });
    document.getElementById('btn-cancel-lead').addEventListener('click', function() {
      document.getElementById('add-panel').classList.remove('open');
    });

    // Save new lead
    document.getElementById('btn-save-lead').addEventListener('click', function() {
      var company = document.getElementById('nl-company').value.trim();
      var contact = document.getElementById('nl-contact').value.trim();
      var email   = document.getElementById('nl-email').value.trim();
      if (!company || !contact || !email) { alert('Company, contact name, and email are required.'); return; }
      var dueVal = document.getElementById('nl-due').value;
      apiCreate({
        companyName:   company,
        contactName:   contact,
        contactEmail:  email,
        contactPhone:  document.getElementById('nl-phone').value.trim() || undefined,
        stage:         document.getElementById('nl-stage').value,
        source:        document.getElementById('nl-source').value,
        vertical:      document.getElementById('nl-vertical').value,
        estimatedValue: parseInt(document.getElementById('nl-value').value) || undefined,
        nextAction:    document.getElementById('nl-action').value.trim() || undefined,
        nextActionDue: dueVal ? new Date(dueVal).toISOString() : undefined,
      }).then(function() {
        renderAll();
        document.getElementById('add-panel').classList.remove('open');
        ['nl-company','nl-contact','nl-email','nl-phone','nl-action','nl-value','nl-due'].forEach(function(id) {
          document.getElementById(id).value = '';
        });
      }).catch(function(e) { alert(e.message); });
    });

    // Search contacts
    document.getElementById('search').addEventListener('input', function() {
      var q = this.value.toLowerCase();
      renderContacts(visibleLeads().filter(function(l) {
        return l.companyName.toLowerCase().includes(q) ||
               l.contactName.toLowerCase().includes(q) ||
               l.contactEmail.toLowerCase().includes(q);
      }));
    });

    fetchLeads();
  });
</script>

<!-- Leads tab logic — plain is:inline, no IIFE wrapping -->
<script is:inline>
  var candidates = [];
  var rejectTargetId = null;

  var CAND_SOURCE_LABELS = {
    linkedin: 'LinkedIn', companies_house: 'Companies House',
    web_search: 'Web Search', legal_directory: 'Legal Directory',
    news: 'News', referral: 'Referral', other: 'Other',
  };

  // ── Fetch candidates ────────────────────────────────────────
  async function fetchCandidates() {
    var res = await fetch('/api/crm/candidates');
    if (res.status === 401) { window.location.href = '/'; return; }
    candidates = await res.json();
    renderLeadsTab();
  }

  // ── Render leads board ──────────────────────────────────────
  function visibleCandidates() {
    return showDemo ? candidates : candidates.filter(function(c) { return !c.isDemo; });
  }

  function renderLeadsTab() {
    var vis = visibleCandidates();
    var inbox    = vis.filter(function(c) { return c.status === 'inbox'; });
    var followup = vis.filter(function(c) { return c.status === 'follow_up'; });
    var rejected = vis.filter(function(c) { return c.status === 'rejected'; });

    document.getElementById('lc-inbox').textContent   = inbox.length;
    document.getElementById('lc-followup').textContent = followup.length;
    document.getElementById('lc-rejected').textContent = rejected.length;

    renderLcards('lcards-inbox',    inbox,    ['followup','reject']);
    renderLcards('lcards-followup', followup, ['promote','reject']);
    renderLcards('lcards-rejected', rejected, ['undo']);
  }

  function renderLcards(containerId, items, actions) {
    var el = document.getElementById(containerId);
    if (!items.length) { el.innerHTML = '<div class="lempty">—</div>'; return; }
    el.innerHTML = items.map(function(c) {
      var actionBtns = actions.map(function(a) {
        var labels = { reject: 'Reject', followup: 'Follow Up', promote: '→ Pipeline', undo: 'Move to Inbox' };
        return '<button class="lcard-btn ' + a + '" data-id="' + esc(c.id) + '" data-action="' + a + '">' + labels[a] + '</button>';
      }).join('');
      return '<div class="lcard ' + c.status + '" data-id="' + esc(c.id) + '">' +
        '<div class="lcard-co">' + esc(c.companyName) + (c.isDemo ? '<span class="demo-badge">demo</span>' : '') + '</div>' +
        '<div class="lcard-ct">' + esc(c.contactName) + ' · ' + esc(c.contactEmail) + '</div>' +
        '<div class="lcard-summary">' + esc(c.summary) + '</div>' +
        '<div class="lcard-meta">' +
          '<span class="lcard-source">' + esc(CAND_SOURCE_LABELS[c.source] || c.source) + '</span>' +
          (c.location ? '<span class="lcard-loc">📍 ' + esc(c.location) + '</span>' : '') +
        '</div>' +
        (c.rejectionReason ? '<div class="lcard-reject-reason">"' + esc(c.rejectionReason) + '"</div>' : '') +
        (c.promotedToLeadId ? '<div class="lcard-promoted">✓ Added to pipeline</div>' : '') +
        '<div class="lcard-actions">' + actionBtns + '</div>' +
      '</div>';
    }).join('');

    // Wire buttons
    el.querySelectorAll('.lcard-btn').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var id     = this.dataset.id;
        var action = this.dataset.action;
        if (action === 'reject') {
          rejectTargetId = id;
          document.getElementById('reject-reason-input').value = '';
          document.getElementById('reject-overlay').classList.add('open');
          setTimeout(function() { document.getElementById('reject-reason-input').focus(); }, 80);
        } else if (action === 'followup') {
          candAction(id, 'followup');
        } else if (action === 'promote') {
          candAction(id, 'promote');
        } else if (action === 'undo') {
          candAction(id, 'inbox');
        }
      });
    });
  }

  async function candAction(id, action, body) {
    var url = '/api/crm/candidates?id=' + id + '&action=' + action;
    var res = await fetch(url, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body || {}),
    });
    if (!res.ok) { var e = await res.json(); throw new Error(e.error || 'Failed'); }
    var data = await res.json();
    // Update local array
    var incoming = data.candidate || data;
    var idx = candidates.findIndex(function(c) { return c.id === incoming.id; });
    if (idx !== -1) candidates[idx] = incoming;
    // If promoted, also add to pipeline leads
    if (data.lead) {
      leads.push(data.lead);
      renderAll();
    }
    renderLeadsTab();
    return data;
  }

  // Boot — wire leads tab + reject modal after DOM ready
  document.addEventListener('DOMContentLoaded', function() {
    // Reject modal confirm
    document.getElementById('btn-reject-confirm').addEventListener('click', function() {
      if (!rejectTargetId) return;
      var reason = (document.getElementById('reject-reason-input').value || '').trim();
      candAction(rejectTargetId, 'reject', { reason: reason }).then(function() {
        document.getElementById('reject-overlay').classList.remove('open');
        rejectTargetId = null;
      }).catch(function(e) { alert('Could not reject: ' + e.message); });
    });

    document.getElementById('btn-reject-cancel').addEventListener('click', function() {
      document.getElementById('reject-overlay').classList.remove('open');
      rejectTargetId = null;
    });

    // Also fetch candidates on load
    fetchCandidates();
  });
</script>

</body>
</html>
