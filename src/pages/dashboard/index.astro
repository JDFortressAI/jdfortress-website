---
import { verifySessionToken, SESSION_COOKIE } from "../../lib/auth";
import { STAGE_LABELS, STAGE_ORDER, STAGE_COLORS, VERTICAL_LABELS, SOURCE_LABELS } from "../../lib/crm";

const token = Astro.cookies.get(SESSION_COOKIE)?.value;
const user  = await verifySessionToken(token);
if (!user) return Astro.redirect("/");

const stageLabels = JSON.stringify(STAGE_LABELS);
const stageOrder  = JSON.stringify(STAGE_ORDER);
const stageColors = JSON.stringify(STAGE_COLORS);
const vertLabels  = JSON.stringify(VERTICAL_LABELS);
const srcLabels   = JSON.stringify(SOURCE_LABELS);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JD Fortress — Dashboard</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #080c18; color: #e5e7eb; min-height: 100vh; }

    /* ── Topbar ──────────────────────────────────────────────── */
    .topbar { background: #0d1b38; border-bottom: 1px solid rgba(255,255,255,0.07); padding: 0 24px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .topbar-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
    .topbar-logo img { height: 28px; }
    .topbar-logo span { color: #fff; font-weight: 700; font-size: 0.95rem; }
    .badge-internal { background: rgba(239,68,68,0.12); color: #f87171; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 2px 7px; border-radius: 4px; border: 1px solid rgba(239,68,68,0.2); }
    .topbar-right { display: flex; align-items: center; gap: 10px; }
    .user-chip { display: flex; align-items: center; gap: 7px; background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 20px; font-size: 0.82rem; color: rgba(255,255,255,0.6); white-space: nowrap; }
    .user-chip .dot { width: 7px; height: 7px; background: #22c55e; border-radius: 50%; flex-shrink: 0; }
    .btn-ghost { background: none; border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.45); padding: 5px 13px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; transition: all 0.15s; }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.28); color: rgba(255,255,255,0.8); }
    .btn-demo-toggle { background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.22); color: rgba(245,158,11,0.6); padding: 5px 13px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .btn-demo-toggle:hover { border-color: rgba(245,158,11,0.45); color: #fbbf24; }
    .btn-demo-toggle.active { background: rgba(245,158,11,0.14); border-color: rgba(245,158,11,0.45); color: #fbbf24; }
    .demo-badge { display: inline-flex; align-items: center; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 1px 5px; border-radius: 3px; background: rgba(245,158,11,0.12); color: rgba(245,158,11,0.7); border: 1px solid rgba(245,158,11,0.18); margin-left: 5px; vertical-align: middle; flex-shrink: 0; }

    /* ── Tabs ────────────────────────────────────────────────── */
    .tabs { background: #0d1b38; border-bottom: 1px solid rgba(255,255,255,0.07); padding: 0 24px; display: flex; gap: 0; overflow-x: auto; }
    .tab { padding: 12px 20px; color: rgba(255,255,255,0.4); font-size: 0.85rem; font-weight: 500; cursor: pointer; border: none; border-bottom: 2px solid transparent; background: none; white-space: nowrap; transition: color 0.15s; }
    .tab:hover { color: rgba(255,255,255,0.7); }
    .tab.active { color: #fff; border-bottom-color: #1E6FF5; }

    /* ── Layout ──────────────────────────────────────────────── */
    .main { padding: 20px 24px; max-width: 1500px; margin: 0 auto; }
    .section { display: none; }
    .section.active { display: block; }

    /* ── Summary strip ───────────────────────────────────────── */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 24px; }
    .stat { background: #111827; border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 16px 18px; }
    .stat.blue  { border-color: rgba(30,111,245,0.25); }
    .stat.green { border-color: rgba(34,197,94,0.25); }
    .stat.amber { border-color: rgba(245,158,11,0.25); }
    .stat.purple{ border-color: rgba(139,92,246,0.25); }
    .stat-lbl { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.09em; color: rgba(255,255,255,0.32); margin-bottom: 6px; }
    .stat-val { font-size: 1.55rem; font-weight: 700; color: #fff; line-height: 1; }
    .stat-sub { font-size: 0.71rem; color: rgba(255,255,255,0.3); margin-top: 4px; }

    /* ── Section header ──────────────────────────────────────── */
    .sh { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; flex-wrap: wrap; gap: 10px; }
    .sh-title { font-size: 0.95rem; font-weight: 700; color: #fff; }
    .btn-primary { background: rgba(30,111,245,0.1); color: #60a5fa; border: 1px solid rgba(30,111,245,0.2); padding: 7px 16px; border-radius: 7px; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .btn-primary:hover { background: rgba(30,111,245,0.2); }
    .btn-blue { background: #1E6FF5; color: #fff; border: none; padding: 9px 18px; border-radius: 7px; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .btn-blue:hover { background: #1558cc; }

    /* ── Add-lead panel ──────────────────────────────────────── */
    .panel { background: #111827; border: 1px solid rgba(255,255,255,0.07); border-radius: 11px; padding: 20px; margin-bottom: 20px; display: none; }
    .panel.open { display: block; }
    .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 12px; }
    .fg { display: flex; flex-direction: column; gap: 5px; }
    .fl { font-size: 0.7rem; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600; }
    .fi, .fsel { background: #1a2236; border: 1px solid rgba(255,255,255,0.09); color: #e5e7eb; border-radius: 7px; padding: 8px 11px; font-size: 0.85rem; font-family: inherit; width: 100%; transition: border-color 0.15s; }
    .fi:focus, .fsel:focus { outline: none; border-color: rgba(30,111,245,0.5); }
    .fsel option { background: #1a2236; }
    .panel-actions { display: flex; gap: 10px; margin-top: 14px; align-items: center; }

    /* ── Kanban ───────────────────────────────────────────────── */
    .kanban-wrap { overflow-x: auto; padding-bottom: 16px; cursor: default; }
    .kanban { display: flex; gap: 14px; min-width: max-content; align-items: flex-start; }
    .kcol { width: 268px; background: #0e1625; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 14px; flex-shrink: 0; transition: background 0.15s; }
    .kcol.drag-over { background: #141f35; border-color: rgba(30,111,245,0.35); }
    .kcol-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .kcol-title { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; }
    .kcol-count { font-size: 0.72rem; background: rgba(255,255,255,0.06); padding: 2px 8px; border-radius: 9px; color: rgba(255,255,255,0.4); }
    .kcards { display: flex; flex-direction: column; gap: 8px; min-height: 48px; }

    /* ── Kanban card ─────────────────────────────────────────── */
    .kcard {
      background: #111827;
      border: 1px solid rgba(255,255,255,0.07);
      border-left: 3px solid transparent;
      border-radius: 8px;
      padding: 12px 13px;
      cursor: grab;
      transition: transform 0.1s, box-shadow 0.1s, border-color 0.15s;
      user-select: none;
    }
    .kcard:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.3); border-color: rgba(255,255,255,0.14); }
    .kcard.dragging { opacity: 0.4; cursor: grabbing; }
    .kcard-company { font-size: 0.88rem; font-weight: 600; color: #f1f5f9; margin-bottom: 2px; }
    .kcard-contact { font-size: 0.75rem; color: rgba(255,255,255,0.38); margin-bottom: 10px; }
    .kcard-row { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
    .vtag { font-size: 0.63rem; background: rgba(30,111,245,0.1); color: #60a5fa; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.06em; flex-shrink: 0; }
    .vval { font-size: 0.75rem; color: rgba(255,255,255,0.5); font-weight: 500; }
    .kcard-action { font-size: 0.7rem; color: rgba(255,255,255,0.28); margin-top: 7px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .kcard-action.overdue { color: #f87171; }
    .kempty { font-size: 0.78rem; color: rgba(255,255,255,0.18); text-align: center; padding: 16px 0; }

    /* ── Customers grid ──────────────────────────────────────── */
    .cust-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .cust-card { background: #111827; border: 1px solid rgba(34,197,94,0.15); border-left: 3px solid #16a34a; border-radius: 11px; padding: 20px; cursor: pointer; transition: border-color 0.15s, transform 0.1s; }
    .cust-card:hover { border-color: rgba(34,197,94,0.35); transform: translateY(-1px); }
    .cust-name { font-size: 1rem; font-weight: 700; color: #f1f5f9; margin-bottom: 4px; }
    .cust-contact { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin-bottom: 14px; }
    .cust-row { display: flex; align-items: center; justify-content: space-between; }
    .cust-value { font-size: 1.05rem; font-weight: 700; color: #4ade80; }
    .cust-date { font-size: 0.75rem; color: rgba(255,255,255,0.3); }
    .cust-notes { margin-top: 10px; font-size: 0.75rem; color: rgba(255,255,255,0.3); }
    .cust-empty { text-align: center; padding: 60px 20px; color: rgba(255,255,255,0.2); font-size: 0.9rem; }

    /* ── Contacts table ──────────────────────────────────────── */
    .tw { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
    thead th { background: #0e1625; color: rgba(255,255,255,0.32); font-size: 0.69rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 11px 14px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.05); font-weight: 600; white-space: nowrap; }
    tbody tr { border-bottom: 1px solid rgba(255,255,255,0.03); cursor: pointer; transition: background 0.1s; }
    tbody tr:hover { background: rgba(255,255,255,0.025); }
    tbody td { padding: 12px 14px; color: #d1d5db; vertical-align: middle; }
    .pill { display: inline-flex; align-items: center; font-size: 0.71rem; font-weight: 600; padding: 3px 9px; border-radius: 11px; white-space: nowrap; }
    .avatar { width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.67rem; font-weight: 700; }
    .search-input { background: #1a2236; border: 1px solid rgba(255,255,255,0.09); color: #e5e7eb; border-radius: 7px; padding: 8px 12px; font-size: 0.85rem; width: 260px; max-width: 100%; }
    .search-input:focus { outline: none; border-color: rgba(30,111,245,0.5); }

    /* ── Analytics ───────────────────────────────────────────── */
    .ag { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
    .ac { background: #111827; border: 1px solid rgba(255,255,255,0.06); border-radius: 11px; padding: 20px; }
    .ac h3 { font-size: 0.7rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 14px; font-weight: 600; }
    .bar-row { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
    .bar-lbl { font-size: 0.75rem; color: rgba(255,255,255,0.5); width: 130px; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .bar-track { flex: 1; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
    .bar-n { font-size: 0.72rem; color: rgba(255,255,255,0.32); width: 42px; text-align: right; flex-shrink: 0; }

    /* ── Modal ───────────────────────────────────────────────── */
    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.72); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
    .overlay.open { display: flex; }
    .modal { background: #111827; border: 1px solid rgba(255,255,255,0.09); border-radius: 14px; width: 100%; max-width: 640px; max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px 16px; border-bottom: 1px solid rgba(255,255,255,0.07); gap: 12px; flex-shrink: 0; }
    .modal-header-left { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 0; }
    .modal-company-input { background: transparent; border: none; color: #f1f5f9; font-size: 1.1rem; font-weight: 700; font-family: inherit; width: 100%; padding: 0; }
    .modal-company-input:focus { outline: none; border-bottom: 1px solid rgba(30,111,245,0.5); }
    .modal-stage-pill { display: inline-flex; align-items: center; font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 10px; white-space: nowrap; align-self: flex-start; }
    .modal-close { background: none; border: none; color: rgba(255,255,255,0.3); font-size: 1.5rem; cursor: pointer; line-height: 1; flex-shrink: 0; padding: 0 0 0 8px; transition: color 0.15s; }
    .modal-close:hover { color: #fff; }
    .modal-body { padding: 20px 24px; overflow-y: auto; flex: 1; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.07); display: flex; gap: 10px; align-items: center; flex-shrink: 0; }
    .modal-section { margin-bottom: 20px; }
    .modal-section-title { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.09em; color: rgba(255,255,255,0.3); font-weight: 600; margin-bottom: 12px; }
    .edit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 520px) { .edit-grid { grid-template-columns: 1fr; } }
    .edit-grid .fg.full { grid-column: 1 / -1; }
    .divider { border: none; border-top: 1px solid rgba(255,255,255,0.06); margin: 16px 0; }

    /* ── Notes ───────────────────────────────────────────────── */
    .notes-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
    .note-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 11px 13px; }
    .note-meta { font-size: 0.69rem; color: rgba(255,255,255,0.25); margin-bottom: 5px; }
    .note-text { font-size: 0.84rem; color: #d1d5db; line-height: 1.6; }
    .note-input { background: #1a2236; border: 1px solid rgba(255,255,255,0.09); color: #e5e7eb; border-radius: 7px; padding: 9px 12px; font-size: 0.85rem; font-family: inherit; width: 100%; min-height: 70px; resize: vertical; transition: border-color 0.15s; }
    .note-input:focus { outline: none; border-color: rgba(30,111,245,0.5); }

    /* ── Misc ────────────────────────────────────────────────── */
    .no-data { font-size: 0.8rem; color: rgba(255,255,255,0.18); text-align: center; padding: 16px; }
    .saved-flash { color: #4ade80; font-size: 0.8rem; display: none; }
    .saved-flash.show { display: inline; }

    /* ── Leads board ─────────────────────────────────────────── */
    .leads-board { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; align-items: start; }
    @media (max-width: 900px) { .leads-board { grid-template-columns: 1fr; } }
    .lcol { background: #0e1625; border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 16px; }
    .lcol-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .lcol-title { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; }
    .lcol-count { font-size: 0.72rem; background: rgba(255,255,255,0.06); padding: 2px 8px; border-radius: 9px; color: rgba(255,255,255,0.4); }
    .lcards { display: flex; flex-direction: column; gap: 10px; min-height: 60px; }

    /* Lead candidate card */
    .lcard { background: #111827; border: 1px solid rgba(255,255,255,0.07); border-radius: 9px; padding: 14px; }
    .lcard.inbox  { border-left: 3px solid #1E6FF5; }
    .lcard.follow_up { border-left: 3px solid #16a34a; }
    .lcard.rejected  { border-left: 3px solid #6b7280; opacity: 0.7; }
    .lcard-co { font-size: 0.9rem; font-weight: 600; color: #f1f5f9; margin-bottom: 2px; }
    .lcard-ct { font-size: 0.76rem; color: rgba(255,255,255,0.38); margin-bottom: 8px; }
    .lcard-summary { font-size: 0.78rem; color: rgba(255,255,255,0.5); line-height: 1.5; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .lcard-meta { display: flex; align-items: center; justify-content: space-between; gap: 6px; flex-wrap: wrap; }
    .lcard-source { font-size: 0.63rem; background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); padding: 2px 7px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .lcard-loc { font-size: 0.73rem; color: rgba(255,255,255,0.3); }
    .lcard-actions { display: flex; gap: 6px; margin-top: 10px; flex-wrap: wrap; }
    .lcard-btn { font-size: 0.72rem; font-weight: 600; padding: 4px 10px; border-radius: 5px; border: none; cursor: pointer; transition: opacity 0.15s; }
    .lcard-btn:hover { opacity: 0.85; }
    .lcard-btn.reject  { background: rgba(107,114,128,0.15); color: #9ca3af; border: 1px solid rgba(107,114,128,0.2); }
    .lcard-btn.followup { background: rgba(22,163,74,0.12); color: #4ade80; border: 1px solid rgba(22,163,74,0.2); }
    .lcard-btn.promote { background: rgba(30,111,245,0.12); color: #60a5fa; border: 1px solid rgba(30,111,245,0.2); }
    .lcard-btn.undo    { background: rgba(245,158,11,0.1); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .lcard-reject-reason { font-size: 0.75rem; color: #9ca3af; font-style: italic; margin-top: 7px; padding: 6px 9px; background: rgba(255,255,255,0.03); border-radius: 5px; }
    .lcard-promoted { font-size: 0.73rem; color: #4ade80; margin-top: 6px; }
    .lempty { font-size: 0.8rem; color: rgba(255,255,255,0.18); text-align: center; padding: 20px 0; }

    /* Reject modal */
    .reject-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 300; align-items: center; justify-content: center; padding: 20px; }
    .reject-overlay.open { display: flex; }
    .reject-box { background: #111827; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 24px; width: 100%; max-width: 440px; }
    .reject-box h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 14px; }
    .reject-box .fl { font-size: 0.7rem; color: rgba(255,255,255,0.38); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600; margin-bottom: 6px; display: block; }
    .reject-reason-input { background: #1a2236; border: 1px solid rgba(255,255,255,0.09); color: #e5e7eb; border-radius: 7px; padding: 9px 12px; font-size: 0.85rem; font-family: inherit; width: 100%; min-height: 80px; resize: vertical; margin-bottom: 14px; }
    .reject-reason-input:focus { outline: none; border-color: rgba(30,111,245,0.5); }
    .reject-actions { display: flex; gap: 10px; }

    @media (max-width: 480px) {
      .topbar-logo span { display: none; }
      .user-chip { display: none; }
    }
  </style>
</head>
<body>

<!-- Topbar -->
<div class="topbar">
  <div class="topbar-left">
    <a href="/" class="topbar-logo">
      <img src="/logo-white.png" alt="JD Fortress AI" />
      <span>JD Fortress AI</span>
    </a>
    <span class="badge-internal">Internal</span>
  </div>
  <div class="topbar-right">
    <button class="btn-demo-toggle" id="btn-demo-toggle" title="Show or hide demo seed data">Demo data: —</button>
    <div class="user-chip"><span class="dot"></span><span id="user-name"></span></div>
    <button class="btn-ghost" id="btn-logout">Sign out</button>
  </div>
</div>

<!-- Tabs -->
<div class="tabs">
  <button class="tab" data-tab="leads">Leads</button>
  <button class="tab active" data-tab="pipeline">Pipeline</button>
  <button class="tab" data-tab="customers">Customers</button>
  <button class="tab" data-tab="contacts">Contacts</button>
  <button class="tab" data-tab="analytics">Analytics</button>
</div>

<div class="main">

  <!-- Stats strip (always visible) -->
  <div class="stats">
    <div class="stat blue"><div class="stat-lbl">Active Leads</div><div class="stat-val" id="s-active">—</div><div class="stat-sub">excl. won &amp; lost</div></div>
    <div class="stat green"><div class="stat-lbl">Pipeline Value</div><div class="stat-val" id="s-pipeline">—</div><div class="stat-sub">active opportunities</div></div>
