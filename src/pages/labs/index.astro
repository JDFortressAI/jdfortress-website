---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const articleCount = blogPosts.length;
---

<Layout
  title="JD Fortress Labs - Secure AI in Action"
  description="Real-world experiments showing what&#x2019;s possible when security, simplicity, and data sovereignty meet. Bible Fortress and the Knowledge Graph."
>

  <!-- HERO -->
  <section style="background:#0F2041; padding:100px 24px 90px; text-align:center;">
    <div style="max-width:760px; margin:0 auto;">
      <p style="color:#1E6FF5; font-size:0.85rem; font-weight:600; letter-spacing:0.12em; text-transform:uppercase; margin:0 0 20px;">JD Fortress Labs</p>
      <h1 style="color:#fff; font-size:clamp(2.2rem, 5vw, 3.4rem); font-weight:700; line-height:1.1; letter-spacing:-0.03em; margin:0 0 24px;">
        Where We Prove What’s Possible
      </h1>
      <p style="color:rgba(255,255,255,0.7); font-size:1.1rem; line-height:1.7; max-width:600px; margin:0 auto;">
        Real-world experiments that showcase what’s possible when security, simplicity, and sovereignty meet. No demos. No vaporware. Running live.
      </p>
    </div>
  </section>

  <!-- PROJECTS -->
  <section style="background:#fff; padding:96px 24px;">
    <div style="max-width:1000px; margin:0 auto; display:flex; flex-direction:column; gap:48px;">

      <!-- Bible Fortress -->
      <div class="labs-card-grid" style="background:#F0F4FF; border:1px solid #e0e8f5; border-radius:16px; padding:48px; display:grid; grid-template-columns:1fr auto; gap:32px; align-items:start;">
        <div>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
            <div style="width:48px; height:48px; background:#0F2041; border-radius:10px; display:flex; align-items:center; justify-content:center;">
              <span style="font-size:1.4rem;">📖</span>
            </div>
            <div>
              <p style="color:#1E6FF5; font-size:0.8rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 4px;">Live Project</p>
              <h2 style="color:#0D141A; font-size:1.4rem; font-weight:700; margin:0;">Bible Fortress</h2>
            </div>
          </div>
          <p style="color:#56585E; font-size:1rem; line-height:1.8; margin:0 0 16px;">
            <strong style="color:#0D141A;">Daily Scripture. Securely Delivered.</strong>
          </p>
          <p style="color:#56585E; font-size:0.95rem; line-height:1.8; margin:0 0 24px;">
            Built to bring focus back to what matters. Following Robert Murray McCheyne’s reading plan, Bible Fortress guides you through four passages a day - with narration and an integrated Q&A chat. No accounts. No cookies. No noise. Just Scripture.
          </p>
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <a href="https://bible.jdfortress.com" target="_blank" rel="noopener" style="background:#1E6FF5; color:#fff; padding:10px 20px; border-radius:6px; text-decoration:none; font-size:0.9rem; font-weight:600;" onmouseover="this.style.background='#1558cc'" onmouseout="this.style.background='#1E6FF5'">
              Visit Bible Fortress →
            </a>
          </div>
        </div>
        <div style="background:#0F2041; border-radius:10px; padding:20px 24px; min-width:180px; text-align:center;">
          <p style="color:rgba(255,255,255,0.5); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 8px;">Features</p>
          <div style="color:rgba(255,255,255,0.8); font-size:0.85rem; line-height:2; text-align:left;">
            <div>✓ McCheyne Reading Plan</div>
            <div>✓ Daily Narration</div>
            <div>✓ Scripture Q&amp;A Chat</div>
            <div>✓ No Accounts</div>
            <div>✓ No Cookies</div>
          </div>
        </div>
      </div>

      <!-- Knowledge Graph -->
      <div class="labs-card-grid" style="background:#080E1E; border:1px solid rgba(30,111,245,0.25); border-radius:16px; padding:48px; display:grid; grid-template-columns:1fr auto; gap:32px; align-items:start; position:relative; overflow:hidden;">
        <!-- Subtle grid bg -->
        <div aria-hidden="true" style="position:absolute; inset:0; background-image:radial-gradient(rgba(30,111,245,0.08) 1px, transparent 1px); background-size:28px 28px; pointer-events:none;"></div>
        <div style="position:relative;">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
            <div style="width:48px; height:48px; background:#1E6FF5; border-radius:10px; display:flex; align-items:center; justify-content:center;">
              <span style="font-size:1.4rem;">🕸️</span>
            </div>
            <div>
              <p style="color:#1E6FF5; font-size:0.8rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 4px;">Live Demo</p>
              <h2 style="color:#fff; font-size:1.4rem; font-weight:700; margin:0;">Knowledge Graph</h2>
            </div>
          </div>
          <p style="color:rgba(255,255,255,0.85); font-size:1rem; line-height:1.8; margin:0 0 16px;">
            <strong style="color:#fff;">Every Article. Every Connection. Live.</strong>
          </p>
          <p style="color:rgba(255,255,255,0.6); font-size:0.95rem; line-height:1.8; margin:0 0 24px;">
            An interactive force-directed graph mapping all {articleCount} JD Fortress blog articles &#x2014; sized by influence, coloured by topic cluster, linked by the cross-references in the prose. Built the way Karpathy describes it: the AI reads once, the structure compounds. Hover to preview. Click to read.
          </p>
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <a href="/labs/knowledge-graph" style="background:#1E6FF5; color:#fff; padding:10px 20px; border-radius:6px; text-decoration:none; font-size:0.9rem; font-weight:600;" onmouseover="this.style.background='#1558cc'" onmouseout="this.style.background='#1E6FF5'">
              Explore the graph →
            </a>
          </div>
        </div>
        <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:20px 24px; min-width:180px; text-align:center; position:relative;">
          <p style="color:rgba(255,255,255,0.4); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 8px;">What you get</p>
          <div style="color:rgba(255,255,255,0.75); font-size:0.85rem; line-height:2; text-align:left;">
            <div>✓ {articleCount} articles mapped</div>
            <div>✓ 5 topic clusters</div>
            <div>✓ Force-directed layout</div>
            <div>✓ Hover previews</div>
            <div>✓ Zoom &amp; pan</div>
          </div>
        </div>
      </div>

      <!-- My Mortgage Insight -->
      <div class="labs-card-grid" style="background:#F0F4FF; border:1px solid #e0e8f5; border-radius:16px; padding:48px; display:grid; grid-template-columns:1fr auto; gap:32px; align-items:start;">
        <div>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
            <div style="width:48px; height:48px; background:#0F2041; border-radius:10px; display:flex; align-items:center; justify-content:center;">
              <span style="font-size:1.4rem;">🏡</span>
            </div>
            <div>
              <p style="color:#1E6FF5; font-size:0.8rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase; margin:0 0 4px;">Live Project</p>
              <h2 style="color:#0D141A; font-size:1.4rem; font-weight:700; margin:0;">My Mortgage Insight</h2>
            </div>
          </div>
          <p style="color:#56585E; font-size:1rem; line-height:1.8; margin:0 0 16px;">
            <strong style="color:#0D141A;">Turning mortgage renewal uncertainty into precise, actionable clarity.</strong>
          </p>
          <p style="color:#56585E; font-size:0.95rem; line-height:1.8; margin:0 0 24px;">
            A demonstration that the best tool isn’t always the most complex one — it’s the one built with genuine empathy for the user’s situation. Homeowners facing renewal knew payments would rise; what they lacked was a clear, honest answer to “by exactly how much?” Three inputs. Instant clarity. Because when UI is designed around a real workplace pain point, that’s where value lives.
          </p>
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <a href="/my-mortgage-insight" style="background:#1E6FF5; color:#fff; padding:10px 20px; border-radius:6px; text-decoration:none; font-size:0.9rem; font-weight:600;" onmouseover="this.style.background='#1558cc'" onmouseout="this.style.background='#1E6FF5'">
              Open the calculator →
            </a>
          </div>
        </div>
        <div style="background:#0F2041; border-radius:10px; padding:20px 24px; min-width:180px; text-align:center;">
          <p style="color:rgba(255,255,255,0.5); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 8px;">Features</p>
          <div style="color:rgba(255,255,255,0.8); font-size:0.85rem; line-height:2; text-align:left;">
            <div>✓ 3 Inputs Only</div>
            <div>✓ Instant Results</div>
            <div>✓ Rate Scenarios</div>
            <div>✓ No Accounts</div>
            <div>✓ No Data Stored</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CLOSING STATEMENT -->
  <section style="background:#0F2041; padding:80px 24px; text-align:center;">
    <div style="max-width:700px; margin:0 auto;">
      <h2 style="color:#fff; font-size:clamp(1.6rem, 3vw, 2.2rem); font-weight:700; letter-spacing:-0.02em; margin:0 0 20px;">
        These aren’t side projects.
      </h2>
      <p style="color:rgba(255,255,255,0.7); font-size:1.05rem; line-height:1.8; margin:0 0 36px;">
        They&#x2019;re proof that secure, private AI is not just possible &#x2014; it&#x2019;s already running. When we say we can deploy this for your business, we&#x2019;ve done it ourselves. Three times. With real users.
      </p>
      <a href="/contact" style="background:#1E6FF5; color:#fff; padding:14px 28px; border-radius:8px; text-decoration:none; font-weight:600; font-size:1rem;" onmouseover="this.style.background='#1558cc'" onmouseout="this.style.background='#1E6FF5'">
        Let’s build yours →
      </a>
    </div>
  </section>


</Layout>

<style is:global>
  @media (max-width: 640px) {
    .labs-card-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
